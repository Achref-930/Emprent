# .env.example — copy to .env.local for local development
# Add these values to Vercel Dashboard → Settings → Environment Variables

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Random secret for signing JWT tokens
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=

# bcrypt hash of your admin password
# Generate with: node -e "require('bcryptjs').hash('YourPassword', 12).then(console.log)"
ADMIN_PASSWORD_HASH=
